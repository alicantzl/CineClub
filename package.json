{
  "name": "cineclub-desktop",
  "version": "1.0.0",
  "homepage": ".",
  "description": "CineClub - Arkadaşlarınızla film izleyin",
  "author": "CineClub Team",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"vite\" \"wait-on tcp:3000 && electron .\"",
    "electron:build": "tsc -b && vite build",
    "dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.cineclub.app",
    "productName": "CineClub",
    "copyright": "Copyright © 2026 CineClub",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.png",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "CineClub"
    }
  },
  "dependencies": {
    "@lottiefiles/dotlottie-react": "^0.18.6",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-query": "^5.90.21",
    "concurrently": "^9.2.1",
    "date-fns": "^4.1.0",
    "firebase": "^12.10.0",
    "lucide-react": "^0.577.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-player": "^3.4.0",
    "react-router-dom": "^7.13.1",
    "react-youtube": "^10.1.0",
    "tailwindcss": "^4.2.1",
    "wait-on": "^9.0.4",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  }
}
